{
  "version": 2,
  "builds": [
    {
      "src": "index.py",
      "use": "@vercel/python"
    },
    {
      "src": "fastapi_app.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/analyze",
      "dest": "fastapi_app.py"
    },
    {
      "src": "/(.*)",
      "dest": "index.py"
    }
  ]
}
